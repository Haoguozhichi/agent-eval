{
  "name": "agent-eval",
  "version": "0.1.0",
  "description": "End-to-end evaluation framework for opencode and other coding agents",
  "type": "module",
  "bin": {
    "agent-eval": "./bin/agent-eval.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run bin/agent-eval.ts",
    "build": "bun build ./bin/agent-eval.ts --outdir ./dist --target bun",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cli-table3": "0.6.5",
    "commander": "13.0.0",
    "dockerode": "4.0.4",
    "eventsource-parser": "3.0.0",
    "hono": "^4.12.19",
    "ora": "8.1.1",
    "p-limit": "6.1.0",
    "picomatch": "4.0.2",
    "tar-stream": "3.1.7",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "@types/dockerode": "3.3.32",
    "@types/node": "22.10.5",
    "@types/picomatch": "3.0.2",
    "@types/tar-stream": "3.1.3",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
